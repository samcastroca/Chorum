# Chorum — variables de entorno de ejemplo.
# Copiá este archivo a `.env` y ajustá los valores. NUNCA commitees `.env` con secretos.
# Invariante (CLAUDE.md #5): las API keys viven en env, nunca en la base de datos de grafos.

# ---- App ----
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Orígenes permitidos para CORS (separados por coma).
CORS_ORIGINS=http://localhost:5173

# ---- Base de datos ----
# Postgres se levanta vía docker compose (servicio `db`).
# Para desarrollo local sin Docker, el default recomendado es SQLite (ver abajo).
POSTGRES_USER=chorum
POSTGRES_PASSWORD=chorum
POSTGRES_DB=chorum
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://chorum:chorum@db:5432/chorum
# Alternativa local sin Docker:
# DATABASE_URL=sqlite:///./chorum.db

# Ruta del SQLite del checkpointer de LangGraph. Vacío = en memoria (default). Apuntarlo a un
# archivo persiste los checkpoints entre reinicios (habilita time-travel sobre ejecuciones
# pasadas, Fase 4). Ej: CHECKPOINTER_DB_PATH=./chorum_checkpoints.db
# CHECKPOINTER_DB_PATH=

# ---- Proveedores de modelos ----
# Vacíos por ahora — se empiezan a usar en la Fase 6. Dejar en blanco si no se usan.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# URL del servicio Ollama. Dentro de docker compose (profile local-models): http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434

# ---- Frontend ----
# Base URL del backend que consume el frontend (inyectada por Vite en build/dev).
VITE_API_BASE_URL=http://localhost:8000
