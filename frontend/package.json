{
  "name": "chorum-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Chorum — canvas visual low-code para construir agentes multi-agente.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
